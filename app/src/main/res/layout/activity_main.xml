<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Michael Sombra"
            android:textSize="28sp"
            android:textColor="#ffffff"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="by Michael Antonio Rodriguez Condega"
            android:textSize="14sp"
            android:textColor="#888888" />

        <Button
            android:id="@+id/btnActivar"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#2ecc71"
            android:text="Activar Sombra"
            android:textSize="16sp"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnDesactivar"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#e74c3c"
            android:text="Desactivar Sombra"
            android:textSize="16sp"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Sombra: INACTIVA ❌"
            android:textSize="14sp"
            android:textColor="#aaaaaa" />

        <!-- 1. ANCHO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Ancho (grosor)"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10dp" android:textSize="12sp" android:textColor="#888888" />
            <SeekBar android:id="@+id/seekAncho" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginHorizontal="12dp" android:max="200" android:progress="90" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="210dp" android:textSize="12sp" android:textColor="#888888" />
        </LinearLayout>
        <TextView android:id="@+id/tvAncho" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="-4dp" android:layout_marginBottom="16dp" android:text="Ancho: 100dp" android:textSize="13sp" android:textColor="#aaaaaa" />

        <!-- 2. ALTURA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. Altura (largo)"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30%" android:textSize="12sp" android:textColor="#888888" />
            <SeekBar android:id="@+id/seekAltura" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginHorizontal="12dp" android:max="70" android:progress="70" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textSize="12sp" android:textColor="#888888" />
        </LinearLayout>
        <TextView android:id="@+id/tvAltura" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="-4dp" android:layout_marginBottom="16dp" android:text="Altura: 100%" android:textSize="13sp" android:textColor="#aaaaaa" />

        <!-- 3. SUBIR ARRIBA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3. Subir arriba (hacia reloj)"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0dp" android:textSize="12sp" android:textColor="#888888" />
            <SeekBar android:id="@+id/seekTopExt" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginHorizontal="12dp" android:max="80" android:progress="0" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="80dp" android:textSize="12sp" android:textColor="#888888" />
        </LinearLayout>
        <TextView android:id="@+id/tvTopExt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="-4dp" android:layout_marginBottom="16dp" android:text="Subir: 0dp" android:textSize="13sp" android:textColor="#aaaaaa" />

        <!-- 4. BAJAR INICIO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4. Bajar inicio (desde el tope)"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0dp" android:textSize="12sp" android:textColor="#888888" />
            <SeekBar android:id="@+id/seekInitDown" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginHorizontal="12dp" android:max="400" android:progress="0" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="400dp" android:textSize="12sp" android:textColor="#888888" />
        </LinearLayout>
        <TextView android:id="@+id/tvInitDown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="-4dp" android:layout_marginBottom="16dp" android:text="Inicio: 0dp abajo" android:textSize="13sp" android:textColor="#aaaaaa" />

        <!-- 5. BAJAR ABAJO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5. Bajar abajo (extender)"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0dp" android:textSize="12sp" android:textColor="#888888" />
            <SeekBar android:id="@+id/seekBotExt" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginHorizontal="12dp" android:max="80" android:progress="0" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="80dp" android:textSize="12sp" android:textColor="#888888" />
        </LinearLayout>
        <TextView android:id="@+id/tvBotExt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="-4dp" android:layout_marginBottom="16dp" android:text="Bajar: 0dp" android:textSize="13sp" android:textColor="#aaaaaa" />

        <!-- 7. ESPACIO EN BORDES (NUEVO) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7. Espacio desde bordes"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0dp" android:textSize="12sp" android:textColor="#888888" />
            <SeekBar android:id="@+id/seekMargin" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginHorizontal="12dp" android:max="100" android:progress="0" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100dp" android:textSize="12sp" android:textColor="#888888" />
        </LinearLayout>
        <TextView android:id="@+id/tvMargin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="-4dp" android:layout_marginBottom="16dp" android:text="Espacio: 0dp" android:textSize="13sp" android:textColor="#aaaaaa" />

        <!-- 8. OSCURIDAD (NUEVO) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8. Oscuridad (opacidad)"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textSize="12sp" android:textColor="#888888" />
            <SeekBar android:id="@+id/seekOpacity" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginHorizontal="12dp" android:max="100" android:progress="50" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textSize="12sp" android:textColor="#888888" />
        </LinearLayout>
        <TextView android:id="@+id/tvOpacity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="-4dp" android:layout_marginBottom="16dp" android:text="Oscuridad: 50%" android:textSize="13sp" android:textColor="#aaaaaa" />

        <!-- 6. INVERTIR -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6. Invertir dirección del gradiente"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:layout_marginBottom="8dp" />
        <Button
            android:id="@+id/btnInvertir"
            android:layout_width="280dp"
            android:layout_height="48dp"
            android:backgroundTint="#555555"
            android:text="Invertir: OFF"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:layout_marginBottom="32dp" />

        <!-- Contacto -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 Contáctame"
            android:textSize="20sp"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnFacebook"
            android:layout_width="280dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#1877F2"
            android:text="Facebook"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:drawableStart="@android:drawable/ic_menu_compass"
            android:drawablePadding="8dp" />

        <Button
            android:id="@+id/btnTelegram"
            android:layout_width="280dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#0088cc"
            android:text="Telegram"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:drawableStart="@android:drawable/ic_menu_send"
            android:drawablePadding="8dp" />

        <Button
            android:id="@+id/btnWhatsApp"
            android:layout_width="280dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#25D366"
            android:text="WhatsApp"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:drawableStart="@android:drawable/ic_menu_share"
            android:drawablePadding="8dp" />

        <Button
            android:id="@+id/btnYouTube"
            android:layout_width="280dp"
            android:layout_height="48dp"
            android:layout_marginBottom="32dp"
            android:backgroundTint="#FF0000"
            android:text="YouTube"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:drawableStart="@android:drawable/ic_menu_gallery"
            android:drawablePadding="8dp" />

    </LinearLayout>

</ScrollView>
